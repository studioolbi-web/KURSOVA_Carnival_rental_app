<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="20.0" alignment="TOP_CENTER" style="-fx-padding: 30; -fx-background-color: -color-bg-default;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oliinyk.costumes.view.CostumeDetailController">
    <ImageView fx:id="imageView" fitWidth="300" fitHeight="300" preserveRatio="true" />
    <Label fx:id="nameLabel" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" />
    <Label fx:id="descLabel" wrapText="true" style="-fx-font-size: 16; -fx-text-fill: -color-fg-muted;" VBox.vgrow="ALWAYS" />
    
    <VBox spacing="10" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 10;">
        <Label fx:id="priceLabel" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: -color-accent-emphasis;" />
        <Label fx:id="depositLabel" style="-fx-font-size: 16; -fx-text-fill: -color-fg-default;" />
    </VBox>
    
    <Button text="Закрити" styleClass="button" onAction="#closeDialog" prefWidth="200" />
</VBox>
