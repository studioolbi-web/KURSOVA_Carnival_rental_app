<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="20.0" style="-fx-padding: 30; -fx-background-color: -color-bg-default;" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oliinyk.costumes.view.AdminPanelController">
    <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: -color-fg-default;" text="Панель Адміністратора" />
    
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <Tab fx:id="dashboardTab" text="Дашборд">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="30" style="-fx-padding: 30;">
                    <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Аналітика прокату" />
                    <HBox spacing="30" alignment="CENTER">
                         <VBox spacing="10" styleClass="card" style="-fx-padding: 20; -fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold;" text="Статуси замовлень" />
                            <javafx.scene.chart.PieChart fx:id="statusChart" />
                         </VBox>
                         <VBox spacing="10" styleClass="card" style="-fx-padding: 20; -fx-background-color: -color-bg-subtle; -fx-border-color: -color-border-default; -fx-border-radius: 10;" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold;" text="Топ-5 популярних костюмів" />
                            <javafx.scene.chart.BarChart fx:id="popularityChart">
                                <xAxis><javafx.scene.chart.CategoryAxis label="Костюм" /></xAxis>
                                <yAxis><javafx.scene.chart.NumberAxis label="Кількість оренд" /></yAxis>
                            </javafx.scene.chart.BarChart>
                         </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>
        <Tab text="Костюми">
            <VBox spacing="10" style="-fx-padding: 20;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Додати Новий Костюм" styleClass="success" onAction="#onAddCostumeClicked">
                        <graphic>
                            <FontIcon iconLiteral="fas-plus" iconColor="white" />
                        </graphic>
                    </Button>
                    <Button text="Backup (JSON)" styleClass="button" onAction="#onBackupCostumesClicked">
                        <graphic>
                            <FontIcon iconLiteral="fas-download" />
                        </graphic>
                    </Button>
                    <Button text="Restore (JSON)" styleClass="button" onAction="#onRestoreCostumesClicked">
                        <graphic>
                            <FontIcon iconLiteral="fas-upload" />
                        </graphic>
                    </Button>
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="costumeSearchField" promptText="Пошук костюмів..." />
                </HBox>
                <TableView fx:id="costumesTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn text="Назва" prefWidth="200" />
                        <TableColumn text="Опис" prefWidth="350" />
                        <TableColumn text="Ціна (грн/день)" prefWidth="120" />
                        <TableColumn text="Дії" prefWidth="180" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <Tab text="Користувачі">
            <VBox spacing="10" style="-fx-padding: 20;">
                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn text="Email" prefWidth="300" />
                        <TableColumn text="Роль" prefWidth="120" />
                        <TableColumn text="Верифікований" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
        
        <Tab text="Оренди">
            <VBox spacing="10" style="-fx-padding: 20;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Експорт у CSV" styleClass="accent" onAction="#onExportRentalsClicked">
                        <graphic>
                            <FontIcon iconLiteral="fas-file-export" />
                        </graphic>
                    </Button>
                </HBox>
                <TableView fx:id="rentalsTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn text="Користувач" prefWidth="250" />
                        <TableColumn text="Дата Початку" prefWidth="150" />
                        <TableColumn text="Дата Кінця" prefWidth="150" />
                        <TableColumn text="Статус" prefWidth="120" />
                        <TableColumn text="Сума" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
